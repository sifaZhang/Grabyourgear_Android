<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:elevation="4dp"
    android:background="@drawable/rounded_bg"
    android:padding="8dp"
    android:layout_margin="6dp">

    <ImageView
        android:id="@+id/img_appl_avatar"
        android:layout_width="100dp"
        android:layout_height="90dp"
        android:background="#DDDDDD"
        android:scaleType="centerCrop"/>

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="10dp">

        <LinearLayout
            android:id="@+id/ly_appl_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:id="@+id/tv_appl_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Supplier Name"
            android:textStyle="bold"
            android:textSize="18sp"
            />

            <TextView
                android:id="@+id/tv_appl_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplier Username"
                android:textSize="12sp"
                />
            <TextView
                android:id="@+id/tv_appl_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplier Email"
                android:textSize="12sp"
                />
            <TextView
                android:id="@+id/tv_appl_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplier Phone No."
                android:textSize="12sp"
                />
            <TextView
                android:id="@+id/tv_appl_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplier Address"
                android:textSize="12sp"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_below="@+id/ly_appl_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_appl_approve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Approve"
                style="@style/AppButtonPrimaryStyle"
                />

            <Button
                android:id="@+id/btn_appl_deny"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Deny"
                style="@style/AppButtonPrimaryStyle"
                android:backgroundTint="#CC0000"
                />
        </LinearLayout>
    </RelativeLayout>





</LinearLayout>

