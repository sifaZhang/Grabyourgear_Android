<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".supplier.SupplierDashboardActivity"
    android:id="@+id/main">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <include
            layout="@layout/layout_common_header"
            android:id="@+id/header" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp">

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actions"
                style="@style/SectionTitle" />

            <!-- Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <!-- Vehicles -->
                <LinearLayout
                    android:id="@+id/lyAddProduct"
                    android:layout_width="0dp"
                    android:elevation="4dp"
                    android:background="@drawable/rounded_bg"
                    style="@style/CommonContainer">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_plus"
                        app:tint="#FF9800" />

                    <TextView
                        android:id="@+id/tvAddProduct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Product"
                        style="@style/TextStyle1"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Construction -->
                <LinearLayout
                    android:id="@+id/lyMyProducts"
                    android:layout_width="0dp"
                    android:elevation="4dp"
                    android:background="@drawable/rounded_bg"
                    style="@style/CommonContainer">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_list"
                        app:tint="#3F51B5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Products"
                        android:id="@+id/tvConstruction"
                        style="@style/TextStyle1"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Orders -->
                <LinearLayout
                    android:id="@+id/lyManageOrders"
                    android:layout_width="0dp"
                    android:elevation="4dp"
                    android:background="@drawable/rounded_bg"
                    style="@style/CommonContainer">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_orders"
                        app:tint="#9C27B0" />

                    <TextView
                        android:id="@+id/tvManageOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Orders"
                        style="@style/TextStyle1"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Profile -->
                <LinearLayout
                    android:id="@+id/lyStoreProfile"
                    android:layout_width="0dp"
                    android:elevation="4dp"
                    android:background="@drawable/rounded_bg"
                    style="@style/CommonContainer">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_storeprofile"
                        app:tint="#4CAF50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Store Profile"
                        android:id="@+id/tvOffice"
                        style="@style/TextStyle1"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </GridLayout>
    </LinearLayout>

    </LinearLayout>

</LinearLayout>
