<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".supplier.SupplierEquipmentDetailActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <include
            layout="@layout/layout_common_header"
            android:id="@+id/header" />

        <!-- Image -->
        <ImageView
            android:id="@+id/imgProductSupplierDetail"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            android:src="@drawable/placeholder_general"/>

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitleSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Deere Lawn Tractor"
                style="@style/SectionTitle"
                android:textSize="28sp"/>

            <!-- Rating -->
            <TextView
                android:id="@+id/tvRatingSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ Rating: 4.5 / 5"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <!-- Location -->
            <TextView
                android:id="@+id/tvLocationSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Location: Christchurch"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Category -->
            <TextView
                android:id="@+id/tvCategorySupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪴 Category: Gardening"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Price -->
            <TextView
                android:id="@+id/tvPriceSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Price: NZD 70 per day"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Discount -->
            <TextView
                android:id="@+id/tvDiscountSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 Discount: 40% OFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tvStatusSupplierDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Status: 40% OFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Description Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                style="@style/SectionTitle"
                android:layout_marginTop="16dp" />

            <!-- Description Content -->
            <TextView
                android:id="@+id/tvDescriptionSupplierDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reliable and powerful lawn tractor, perfect for maintaining medium to large gardens. Easy to operate with smooth handling and a comfortable seat. Ideal for cutting grass quickly and efficiently, even on slightly uneven terrain. Well-maintained and ready to use."
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <Button
                    android:id="@+id/btnPrimaryDetail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/AppButtonPrimaryStyle"
                    android:text="Edit" />

                <Button
                    android:id="@+id/btnSecondaryDetail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="10dp"
                    style="@style/AppButtonPrimaryStyle"
                    android:text="Delete" />

                <Button
                    android:id="@+id/btnBackDetail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="10dp"
                    style="@style/AppButtonPrimaryStyle"
                    android:text="Go Back" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>