<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:elevation="4dp"
    android:background="@drawable/rounded_bg"
    android:padding="8dp"
    android:layout_margin="6dp">

    <ImageView
        android:id="@+id/imgEquipment"
        android:layout_width="100dp"
        android:layout_height="108dp"
        android:background="#DDDDDD"
        android:scaleType="centerCrop" />

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingStart="10dp">

        <TextView
            android:id="@+id/tvItemCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="-4dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true" />

        <Button
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:text="Cancel"
            style="@style/AppButtonPrimaryStyle"
            android:textSize="12sp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:padding="0dp"
            android:id="@+id/btnCancel"/>

        <Button
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:text="Rate"
            style="@style/AppButtonPrimaryStyle"
            android:textSize="12sp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:padding="0dp"
            android:id="@+id/btnRate"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deal Title"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="5dp"
                android:layout_below="@id/tvItemCategory" />

            <TextView
                android:id="@+id/tvDateRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DateRange"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvItemLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TotalPrice"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvItemStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvItemRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating"
                android:textSize="12sp"/>

        </LinearLayout>
    </RelativeLayout>

</LinearLayout>
